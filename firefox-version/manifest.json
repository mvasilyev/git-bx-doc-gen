{
  "manifest_version": 2,
  "name": "GitLab MR Documentation Generator (Firefox)",
  "version": "1.0.0",
  "description": "Automatically generates documentation for GitLab merge requests using AI",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "contextMenus",
    "*://*.gitlab.com/*",
    "*://*.gitlab.io/*",
    "*://git.bx/*",
    "http://*/*",
    "https://*/*"
  ],
  "content_security_policy": "script-src 'self'; object-src 'self'; connect-src 'self' https: http:;",
  "content_scripts": [
    {
      "matches": [
        "*://*.gitlab.com/*/merge_requests/*",
        "*://*.gitlab.io/*/merge_requests/*",
        "*://git.bx/*/merge_requests/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "GitLab MR Doc Generator"
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "web_accessible_resources": [
    "assets/*"
  ],
  "applications": {
    "gecko": {
      "id": "gitlab-mr-doc-gen@example.com",
      "strict_min_version": "57.0"
    }
  }
}
